const STAT_LABELS = {
    pow: 'POWER',
    spd: 'SPEED',
    brn: 'BRAIN',
    cha: 'CHARISMA',
    wil: 'WILLPOWER'
};

// ============================================================
// RENDER FUNCTIONS
// ============================================================

function renderSoulTag(soulKey) {
    const soul = SOUL_DATA[soulKey];
    if (!soul) return '';
    return `<span class="soul-tag ${soulKey}"><span class="soul-icon">${soul.icon}</span> ${soul.label}</span>`;
}

function renderMissionCard(mission, index, isGroup) {
    const affinities = Array.isArray(mission.a) ? mission.a : [mission.a];
    const soulTags = affinities.map(a => renderSoulTag(a)).join('');
    const num = String(index + 1).padStart(isGroup ? 2 : 3, '0');
    const easyPts = isGroup ? 2 : 1;
    const hardPts = isGroup ? 4 : 2;
    const groupLabel = isGroup ? `<div class="group-label">GROUP MISSION</div>` : '';

    return `<div class="mission-card">
        <div class="card-frame">
            <div class="card-inner">
                <div class="stat-header ${mission.s}">
                    <span class="card-num">#${num}</span>
                    ${groupLabel}
                    ${STAT_LABELS[mission.s]}
                </div>
                <div class="card-body">
                    <div class="card-title">${mission.t}</div>
                    <div class="card-desc">${mission.d}</div>
                    <div class="diff-row">
                        <div class="diff-box easy">
                            <div class="diff-label">EASY</div>
                            <div class="diff-value">${mission.e}</div>
                            <div class="diff-pts">${easyPts} pt${easyPts > 1 ? 's' : ''}</div>
                        </div>
                        <div class="diff-box hard">
                            <div class="diff-label">HARD</div>
                            <div class="diff-value">${mission.h}</div>
                            <div class="diff-pts">${hardPts} pts</div>
                        </div>
                    </div>
                    <div class="affinity-section">
                        <div class="affinity-label">AFFINITY BONUS:</div>
                        <div class="soul-tags">${soulTags}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>`;
}

function renderHeroCard(hero) {
    const soul = SOUL_DATA[hero.a];
    const stats = ['pow','spd','brn','cha','wil'];
    const statLabels = {pow:'POW', spd:'SPD', brn:'BRN', cha:'CHA', wil:'WIL'};

    const statRows = stats.map(s => `
        <div class="stat-row">
            <div class="stat-color-bar ${s}"></div>
            <div style="flex:1;">
                <div class="stat-value">${hero.s[s]}</div>
                <div class="stat-name">${statLabels[s]}</div>
            </div>
        </div>
    `).join('');

    return `<div class="hero-card">
        <div class="card-frame">
            <div class="card-inner">
                <div class="hero-header">
                    <img class="hero-portrait" src="${hero.i}" alt="${hero.n}" onerror="this.style.background='#333'; this.alt='[${hero.n}]';">
                    <div class="hero-info">
                        <div class="hero-name">${hero.n}</div>
                        <div class="soul-badge ${hero.a}">
                            <span class="soul-icon">${soul.icon}</span> ${soul.label} Soul
                        </div>
                    </div>
                </div>
                <div class="stat-table">
                    ${statRows}
                </div>
                <div class="passive-section">
                    <div class="passive-title">PASSIVE: ${hero.passive}</div>
                    <div class="passive-desc">${hero.passiveDesc}</div>
                </div>
                <div class="flavor-text">${hero.quote}</div>
            </div>
        </div>
    </div>`;
}

