<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pavel Missions - Γεννητρια Καρτων (Εκδοση Ψυχων)</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=MedievalSharp&family=Almendra:ital@0;1&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    background: #1a1a2e;
    color: #d4c5a0;
    font-family: 'MedievalSharp', serif;
    padding: 20px;
}

.controls {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #1a1a2e;
    padding: 15px 0;
    border-bottom: 2px solid #8e7b55;
    margin-bottom: 20px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
}
.controls button {
    padding: 10px 20px;
    font-family: 'MedievalSharp', serif;
    font-size: 16px;
    cursor: pointer;
    border: 2px solid #8e7b55;
    border-radius: 6px;
    color: #d4c5a0;
    background: #2a1a1a;
}
.controls button:hover { background: #3a2a1a; }
.controls button.active { background: #5a3a1a; border-color: #f3cf7a; }
.controls .note {
    font-size: 13px;
    color: #888;
    margin-left: 15px;
}

.card-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
}

/* ========================================
   MISSION CARD
   ======================================== */
.mission-card {
    width: 350px;
    min-height: 520px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    page-break-inside: avoid;
    display: flex;
    flex-direction: column;
}

/* Outer border/frame */
.mission-card .card-frame {
    border: 4px solid #8B4513;
    border-radius: 12px;
    background: linear-gradient(135deg, #c4a265 0%, #d4c196 25%, #b89b5e 50%, #d4c196 75%, #c4a265 100%);
    padding: 3px;
    flex: 1;
    display: flex;
    flex-direction: column;
}

.mission-card .card-inner {
    border: 2px solid #8B4513;
    border-radius: 8px;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
}

/* Stat header bar */
.mission-card .stat-header {
    text-align: center;
    padding: 8px 12px;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 1px 1px 3px rgba(0,0,0,0.5);
    position: relative;
}
.mission-card .stat-header .card-num {
    position: absolute;
    left: 8px;
    top: 8px;
    font-size: 10px;
    font-family: 'MedievalSharp', serif;
    opacity: 0.7;
}

.stat-header.pow { background: linear-gradient(135deg, #8B0000, #c0392b); border-bottom: 3px solid #5a0000; }
.stat-header.spd { background: linear-gradient(135deg, #1565C0, #2196F3); border-bottom: 3px solid #0D47A1; }
.stat-header.brn { background: linear-gradient(135deg, #6A1B9A, #9C27B0); border-bottom: 3px solid #4A148C; }
.stat-header.cha { background: linear-gradient(135deg, #E65100, #FF9800); border-bottom: 3px solid #BF360C; }
.stat-header.wil { background: linear-gradient(135deg, #1B5E20, #4CAF50); border-bottom: 3px solid #1B5E20; }

/* Card body */
.mission-card .card-body {
    padding: 18px 16px 12px;
    flex: 1;
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, rgba(196,162,101,0.3) 0%, rgba(180,148,88,0.15) 100%);
}

.mission-card .card-title {
    font-family: 'Almendra', serif;
    font-style: italic;
    font-size: 22px;
    color: #3a2a1a;
    text-align: center;
    margin-bottom: 6px;
}

.mission-card .card-desc {
    font-size: 14px;
    color: #5a4a3a;
    text-align: center;
    margin-bottom: 16px;
    line-height: 1.3;
}

/* Difficulty boxes */
.mission-card .diff-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 16px;
}
.diff-box {
    border-radius: 8px;
    padding: 8px;
    text-align: center;
}
.diff-box.easy {
    background: rgba(27, 94, 32, 0.12);
    border: 2px solid #4CAF50;
}
.diff-box.hard {
    background: rgba(139, 0, 0, 0.08);
    border: 2px solid #c0392b;
}
.diff-box .diff-label {
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 2px;
    margin-bottom: 2px;
}
.diff-box.easy .diff-label { color: #1B5E20; }
.diff-box.hard .diff-label { color: #8B0000; }
.diff-box .diff-value {
    font-size: 36px;
    font-weight: bold;
    line-height: 1;
}
.diff-box.easy .diff-value { color: #2E7D32; }
.diff-box.hard .diff-value { color: #c0392b; }
.diff-box .diff-pts {
    font-size: 12px;
    color: #5a4a3a;
    margin-top: 4px;
}

/* Affinity section */
.mission-card .affinity-section {
    text-align: center;
    margin-top: auto;
}
.mission-card .affinity-label {
    font-size: 11px;
    color: #8a7a5a;
    letter-spacing: 2px;
    margin-bottom: 6px;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 400;
}
.mission-card .soul-tags {
    display: flex;
    gap: 6px;
    justify-content: center;
    flex-wrap: wrap;
}
.soul-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: bold;
    letter-spacing: 1px;
    text-transform: uppercase;
    border: 1px solid;
}
.soul-tag .soul-icon { font-size: 13px; }

/* Soul type colors */
.soul-tag.dark    { background: #2a1a2a; color: #c9a0dc; border-color: #6a3a6a; }
.soul-tag.tech    { background: #1a2a3a; color: #7ac4f3; border-color: #3a6a8a; }
.soul-tag.stone   { background: #3a3028; color: #c8b080; border-color: #7a6a50; }
.soul-tag.crowd   { background: #3a2818; color: #e8c070; border-color: #8a7040; }
.soul-tag.magic   { background: #2a1a3a; color: #b080e8; border-color: #6a3a9a; }
.soul-tag.shadow  { background: #1a1a28; color: #9090c0; border-color: #5050a0; }
.soul-tag.sky     { background: #182838; color: #88c8f0; border-color: #3878a8; }
.soul-tag.pub     { background: #382818; color: #d8a850; border-color: #906828; }
.soul-tag.silent  { background: #283028; color: #a0c8a0; border-color: #507850; }
.soul-tag.undead  { background: #2a2018; color: #c0a070; border-color: #786040; }

/* Group mission label */
.mission-card .group-label {
    text-align: center;
    font-size: 11px;
    font-family: 'Cinzel Decorative', serif;
    color: #fff;
    letter-spacing: 3px;
    padding: 2px 0 0;
    font-weight: 700;
}

/* ========================================
   HERO CARD
   ======================================== */
.hero-card {
    width: 350px;
    min-height: 620px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    page-break-inside: avoid;
}

.hero-card .card-frame {
    border: 4px solid #8B4513;
    border-radius: 12px;
    background: linear-gradient(135deg, #c4a265 0%, #d4c196 25%, #b89b5e 50%, #d4c196 75%, #c4a265 100%);
    padding: 3px;
    height: 100%;
    display: flex;
    flex-direction: column;
}

.hero-card .card-inner {
    border: 2px solid #8B4513;
    border-radius: 8px;
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(196,162,101,0.3) 0%, rgba(180,148,88,0.15) 100%);
}

/* Hero header with image and name */
.hero-card .hero-header {
    display: flex;
    align-items: flex-start;
    padding: 12px 12px 8px;
    gap: 12px;
    position: relative;
}

.hero-card .hero-portrait {
    width: 90px;
    height: 90px;
    border: 3px solid #8B4513;
    border-radius: 6px;
    object-fit: cover;
    background: #000;
    flex-shrink: 0;
}

.hero-card .hero-info {
    flex: 1;
    padding-top: 4px;
}

.hero-card .hero-name {
    font-family: 'Almendra', serif;
    font-style: italic;
    font-size: 24px;
    color: #3a2a1a;
    line-height: 1.1;
    margin-bottom: 4px;
}

.hero-card .hero-soul-line {
    font-size: 12px;
    color: #6a5a4a;
}

/* Soul badge - NEW prominent design */
.hero-card .soul-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: bold;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 6px;
    border: 2px solid;
}
.soul-badge.dark    { background: #2a1a2a; color: #c9a0dc; border-color: #8a5a9a; }
.soul-badge.tech    { background: #1a2a3a; color: #7ac4f3; border-color: #4a8aba; }
.soul-badge.stone   { background: #3a3028; color: #c8b080; border-color: #9a8a60; }
.soul-badge.crowd   { background: #3a2818; color: #e8c070; border-color: #b09050; }
.soul-badge.magic   { background: #2a1a3a; color: #b080e8; border-color: #8a5aba; }
.soul-badge.shadow  { background: #1a1a28; color: #9090c0; border-color: #7070b0; }
.soul-badge.sky     { background: #182838; color: #88c8f0; border-color: #5898c8; }
.soul-badge.pub     { background: #382818; color: #d8a850; border-color: #b08838; }
.soul-badge.silent  { background: #283028; color: #a0c8a0; border-color: #709870; }
.soul-badge.undead  { background: #2a2018; color: #c0a070; border-color: #987850; }
.soul-badge .soul-icon { font-size: 15px; }

/* Stat rows */
.hero-card .stat-table {
    padding: 8px 12px;
}
.hero-card .stat-row {
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(139, 69, 19, 0.2);
    padding: 4px 0;
}
.hero-card .stat-color-bar {
    width: 6px;
    height: 28px;
    border-radius: 2px;
    margin-right: 10px;
    flex-shrink: 0;
}
.stat-color-bar.pow { background: #c0392b; }
.stat-color-bar.spd { background: #2196F3; }
.stat-color-bar.brn { background: #9C27B0; }
.stat-color-bar.cha { background: #FF9800; }
.stat-color-bar.wil { background: #4CAF50; }

.hero-card .stat-value {
    font-size: 24px;
    font-weight: bold;
    color: #3a2a1a;
    width: 40px;
    text-align: center;
}
.hero-card .stat-name {
    font-size: 11px;
    color: #8a7a5a;
    letter-spacing: 1px;
    text-transform: uppercase;
}

/* Passive section */
.hero-card .passive-section {
    margin: 8px 12px;
    border: 2px solid #8B4513;
    border-radius: 6px;
    padding: 10px;
    background: rgba(255,255,255,0.06);
}
.hero-card .passive-title {
    font-size: 14px;
    font-weight: bold;
    color: #3a2a1a;
    margin-bottom: 6px;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 12px;
}
.hero-card .passive-desc {
    font-size: 13px;
    color: #5a4a3a;
    line-height: 1.4;
}

/* Flavor text */
.hero-card .flavor-text {
    margin-top: auto;
    padding: 10px 16px 12px;
    text-align: right;
    font-style: italic;
    font-size: 12px;
    color: #8a7a5a;
}

/* Soul icons map */
.soul-icon-text::before { content: attr(data-icon); }

/* ========================================
   STAT REFERENCE CARD
   ======================================== */
.stat-card {
    width: 350px;
    min-height: 520px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    page-break-inside: avoid;
    display: flex;
    flex-direction: column;
}

.stat-card .card-frame {
    border: 4px solid;
    border-radius: 12px;
    padding: 3px;
    flex: 1;
    display: flex;
    flex-direction: column;
}
.stat-card .card-frame.pow { border-color: #8B0000; background: linear-gradient(135deg, #3a1515, #5a2020 40%, #3a1515 100%); }
.stat-card .card-frame.spd { border-color: #0D47A1; background: linear-gradient(135deg, #0a1a30, #152a50 40%, #0a1a30 100%); }
.stat-card .card-frame.brn { border-color: #4A148C; background: linear-gradient(135deg, #1a0a30, #2a1550 40%, #1a0a30 100%); }
.stat-card .card-frame.cha { border-color: #BF360C; background: linear-gradient(135deg, #301a0a, #4a2a10 40%, #301a0a 100%); }
.stat-card .card-frame.wil { border-color: #1B5E20; background: linear-gradient(135deg, #0a1a0a, #152a15 40%, #0a1a0a 100%); }

.stat-card .card-inner {
    border: 2px solid;
    border-radius: 8px;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.stat-card .card-inner.pow { border-color: #5a0000; }
.stat-card .card-inner.spd { border-color: #0D47A1; }
.stat-card .card-inner.brn { border-color: #4A148C; }
.stat-card .card-inner.cha { border-color: #BF360C; }
.stat-card .card-inner.wil { border-color: #1B5E20; }

.stat-card .stat-card-header {
    text-align: center;
    padding: 24px 16px 12px;
}
.stat-card .stat-abbr {
    font-family: 'Almendra', serif;
    font-style: italic;
    font-size: 52px;
    line-height: 1;
    margin-bottom: 2px;
}
.stat-card .stat-fullname {
    font-family: 'Cinzel Decorative', serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
}
.stat-card.pow .stat-abbr, .stat-card.pow .stat-fullname { color: #f3cf7a; }
.stat-card.spd .stat-abbr, .stat-card.spd .stat-fullname { color: #88c8f0; }
.stat-card.brn .stat-abbr, .stat-card.brn .stat-fullname { color: #c9a0dc; }
.stat-card.cha .stat-abbr, .stat-card.cha .stat-fullname { color: #f0c878; }
.stat-card.wil .stat-abbr, .stat-card.wil .stat-fullname { color: #a0d8a0; }

.stat-card .stat-card-body {
    padding: 0 20px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
}

.stat-card .stat-flavor {
    text-align: center;
    font-size: 14px;
    color: #c8b898;
    line-height: 1.4;
    margin-bottom: 18px;
    padding: 0 8px;
    font-style: italic;
}

.stat-card .stat-divider {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
}
.stat-card .stat-divider-line {
    flex: 1;
    height: 1px;
    opacity: 0.3;
}
.stat-card.pow .stat-divider-line { background: #c0392b; }
.stat-card.spd .stat-divider-line { background: #2196F3; }
.stat-card.brn .stat-divider-line { background: #9C27B0; }
.stat-card.cha .stat-divider-line { background: #FF9800; }
.stat-card.wil .stat-divider-line { background: #4CAF50; }

.stat-card .stat-divider-icon {
    font-size: 10px;
    opacity: 0.5;
}

.stat-card .stat-section-title {
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 13px;
    text-align: center;
    letter-spacing: 2px;
    margin-bottom: 10px;
}
.stat-card.pow .stat-section-title { color: #f3cf7a; }
.stat-card.spd .stat-section-title { color: #88c8f0; }
.stat-card.brn .stat-section-title { color: #c9a0dc; }
.stat-card.cha .stat-section-title { color: #f0c878; }
.stat-card.wil .stat-section-title { color: #a0d8a0; }

.stat-card .example-challenge {
    margin-bottom: 8px;
    padding-left: 4px;
}
.stat-card .example-name {
    font-size: 14px;
    font-weight: bold;
    color: #d8c8a8;
}
.stat-card .example-name::before {
    content: '◆ ';
    font-size: 10px;
}
.stat-card .example-desc {
    font-size: 12px;
    color: #a09080;
    padding-left: 14px;
}

.stat-card .skilled-section {
    margin-top: auto;
    padding-top: 12px;
}
.stat-card .skilled-title {
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 13px;
    text-align: center;
    letter-spacing: 2px;
    margin-bottom: 8px;
}
.stat-card.pow .skilled-title { color: #f3cf7a; }
.stat-card.spd .skilled-title { color: #88c8f0; }
.stat-card.brn .skilled-title { color: #c9a0dc; }
.stat-card.cha .skilled-title { color: #f0c878; }
.stat-card.wil .skilled-title { color: #a0d8a0; }

.stat-card .skilled-tags {
    display: flex;
    gap: 6px;
    justify-content: center;
    flex-wrap: wrap;
}

.stat-card .stat-card-footer {
    text-align: center;
    padding: 16px 12px 12px;
    margin-top: auto;
}
.stat-card .footer-warning {
    font-size: 13px;
    color: #c8a878;
    font-weight: bold;
}
.stat-card .footer-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.5;
    margin-top: 4px;
    color: #a09080;
}

/* Print styles */
@media print {
    body { background: white; padding: 0; }
    .controls { display: none; }
    .card-grid { gap: 10px; }
    .mission-card, .hero-card { break-inside: avoid; }
    .book-page { break-inside: avoid; box-shadow: none !important; }
}

/* ========================================
   BOOKLET PAGES
   ======================================== */
.book-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
}

.book-page {
    width: 700px;
    min-height: 960px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    page-break-inside: avoid;
    display: flex;
    flex-direction: column;
}

.book-page .book-frame {
    border: 4px solid #5a3a1a;
    border-radius: 12px;
    background: linear-gradient(135deg, #2a1a0e 0%, #1a1020 50%, #2a1a0e 100%);
    padding: 3px;
    flex: 1;
    display: flex;
    flex-direction: column;
}

.book-page .book-inner {
    border: 2px solid #8e7b55;
    border-radius: 8px;
    padding: 35px 40px;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(26,16,10,0.95) 0%, rgba(20,12,30,0.95) 100%);
}

.book-page .book-inner::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%238e7b55' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
}

.book-page .book-inner > * { position: relative; z-index: 1; }

.book-title {
    font-family: 'Cinzel Decorative', serif;
    font-size: 26px;
    color: #f3cf7a;
    text-align: center;
    margin-bottom: 8px;
    text-shadow: 0 0 15px rgba(243,207,122,0.3);
}

.book-subtitle {
    font-family: 'Almendra', serif;
    font-size: 15px;
    color: #b89b5e;
    text-align: center;
    font-style: italic;
    margin-bottom: 20px;
}

.book-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 16px 0;
}
.book-divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, #8e7b55, transparent);
}
.book-divider-icon {
    color: #f3cf7a;
    font-size: 12px;
}

.book-heading {
    font-family: 'Cinzel Decorative', serif;
    font-size: 17px;
    color: #f3cf7a;
    margin: 12px 0 8px;
}

.book-subheading {
    font-family: 'Almendra', serif;
    font-size: 15px;
    color: #d4a76a;
    font-weight: bold;
    margin: 10px 0 5px;
}

.book-text {
    font-family: 'Almendra', serif;
    font-size: 14px;
    color: #c8b88a;
    line-height: 1.6;
    margin-bottom: 8px;
}

.book-text em { color: #f3cf7a; font-style: italic; }
.book-text strong { color: #d4a76a; }

.book-quote {
    font-family: 'Almendra', serif;
    font-style: italic;
    font-size: 13px;
    color: #a89060;
    border-left: 3px solid #8e7b55;
    padding: 8px 15px;
    margin: 10px 0;
    background: rgba(142,123,85,0.08);
    border-radius: 0 6px 6px 0;
}

.book-npc {
    background: rgba(142,123,85,0.1);
    border: 1px solid rgba(142,123,85,0.3);
    border-radius: 8px;
    padding: 12px 15px;
    margin: 8px 0;
}
.book-npc-name {
    font-family: 'Cinzel Decorative', serif;
    font-size: 14px;
    color: #f3cf7a;
    margin-bottom: 4px;
}
.book-npc-desc {
    font-family: 'Almendra', serif;
    font-size: 13px;
    color: #c8b88a;
    line-height: 1.5;
}

.book-rule-box {
    background: rgba(139,0,0,0.1);
    border: 1px solid rgba(139,0,0,0.3);
    border-radius: 8px;
    padding: 12px 15px;
    margin: 8px 0;
}
.book-rule-title {
    font-family: 'Cinzel Decorative', serif;
    font-size: 14px;
    color: #ff6b6b;
    margin-bottom: 6px;
}
.book-rule-text {
    font-family: 'Almendra', serif;
    font-size: 13px;
    color: #c8b88a;
    line-height: 1.5;
}

.book-list {
    font-family: 'Almendra', serif;
    font-size: 13px;
    color: #c8b88a;
    line-height: 1.7;
    padding-left: 20px;
    margin: 6px 0;
}
.book-list li { margin-bottom: 3px; }
.book-list li strong { color: #f3cf7a; }

.book-ability {
    background: rgba(243,207,122,0.06);
    border-left: 3px solid #8e7b55;
    padding: 6px 12px;
    margin: 5px 0;
    border-radius: 0 6px 6px 0;
}
.book-ability-name {
    font-family: 'Almendra', serif;
    font-size: 13px;
    color: #f3cf7a;
    font-weight: bold;
}
.book-ability-desc {
    font-family: 'Almendra', serif;
    font-size: 12px;
    color: #a89060;
    line-height: 1.4;
}

.book-page-num {
    text-align: center;
    font-family: 'Cinzel Decorative', serif;
    font-size: 12px;
    color: #8e7b55;
    margin-top: auto;
    padding-top: 15px;
}

.book-footer {
    text-align: center;
    font-family: 'Almendra', serif;
    font-size: 11px;
    color: #5a4a2a;
    font-style: italic;
    margin-top: 5px;
}

/* Section title */
.section-title {
    width: 100%;
    text-align: center;
    font-family: 'Cinzel Decorative', serif;
    font-size: 28px;
    color: #f3cf7a;
    margin: 30px 0 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid #8e7b55;
}

.hidden { display: none !important; }

/* Soul legend */
.soul-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin: 15px 0;
    padding: 15px;
    background: rgba(0,0,0,0.3);
    border-radius: 8px;
    border: 1px solid #8e7b55;
}
.soul-legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
}
.soul-legend-item .soul-tag { font-size: 11px; }
.soul-legend-item .hero-names {
    color: #888;
    font-size: 11px;
}
</style>
</head>
<body>

<h1 style="text-align:center; font-family:'Cinzel Decorative',serif; color:#f3cf7a; margin-bottom:5px;">Pavel Missions - Γεννητρια Καρτων</h1>
<p style="text-align:center; color:#888; font-size:14px; margin-bottom:20px;">Εκδοση Ψυχων - Τα μπονους συγγενειας χρησιμοποιουν τυπους Ψυχης αντι για ονοματα ηρωων</p>

<div class="controls">
    <button onclick="showSection('missions')" id="btn-missions" class="active">Αποστολες (100)</button>
    <button onclick="showSection('group')" id="btn-group">Ομαδικες Αποστολες (50)</button>
    <button onclick="showSection('heroes')" id="btn-heroes">Ηρωες (13)</button>
    <button onclick="showSection('stats')" id="btn-stats">Καρτες Στατιστικων (5)</button>
    <button onclick="showSection('world')" id="btn-world">Βιβλιο του Κοσμου</button>
    <button onclick="showSection('rules')" id="btn-rules">Βιβλιο Κανονων</button>
    <button onclick="showSection('all')" id="btn-all">Εμφανιση Ολων</button>
    <button onclick="window.print()" style="background:#1B5E20; border-color:#4CAF50;">Εκτυπωση / Αποθηκευση PDF</button>
    <span class="note">Δεξι κλικ σε καρτα → "Αποθηκευση εικονας" ή Εκτυπωση για εξαγωγη PDF</span>
</div>

<!-- Soul Legend -->
<div class="soul-legend" id="soul-legend">
    <div style="width:100%; text-align:center; font-weight:bold; font-size:14px; margin-bottom:5px; color:#f3cf7a;">ΤΥΠΟΙ ΨΥΧΗΣ → ΗΡΩΕΣ</div>
</div>

<div id="missions-section">
    <h2 class="section-title">Καρτες Αποστολων (1-100)</h2>
    <div class="card-grid" id="missions-grid"></div>
</div>

<div id="group-section" class="hidden">
    <h2 class="section-title">Καρτες Ομαδικων Αποστολων (1-50)</h2>
    <div class="card-grid" id="group-grid"></div>
</div>

<div id="heroes-section" class="hidden">
    <h2 class="section-title">Καρτες Ηρωων</h2>
    <div class="card-grid" id="heroes-grid"></div>
</div>

<div id="stats-section" class="hidden">
    <h2 class="section-title">Καρτες Αναφορας Στατιστικων</h2>
    <div class="card-grid" id="stats-grid"></div>
</div>

<div id="world-section" class="hidden">
    <h2 class="section-title">Book of the World</h2>
    <div class="book-grid" id="world-grid"></div>
</div>

<div id="rules-section" class="hidden">
    <h2 class="section-title">Book of Game Rules</h2>
    <div class="book-grid" id="rules-grid"></div>
</div>

<script>
// ============================================================
// SOUL SYSTEM
// ============================================================

const SOUL_DATA = {
    dark:   { icon: '🌑', label: 'Dark',   heroes: ['Dark Stalker', 'Devil Boy', 'Forest Spirit'] },
    tech:   { icon: '⚙️', label: 'Tech',   heroes: ['Friendly AI'] },
    stone:  { icon: '🪨', label: 'Stone',  heroes: ['Thug Dwarf', 'Warrior Girl'] },
    crowd:  { icon: '👥', label: 'Crowd',  heroes: ['Babbler Rogue'] },
    magic:  { icon: '✨', label: 'Magic',  heroes: ['Neighbor Witch', 'Ancient Tree Elder', 'Wizard of Orks'] },
    shadow: { icon: '🌫️', label: 'Shadow', heroes: ['Fancy Ninja', 'Quick Thief', 'Monkey Boy'] },
    sky:    { icon: '☁️', label: 'Sky',    heroes: ['Lost Dragon'] },
    pub:    { icon: '🍺', label: 'Pub',    heroes: ['Drunken Paladin', 'Another Drunk Guy'] },
    silent: { icon: '🤫', label: 'Silent', heroes: ['Mute Monk', 'Sad Troll', 'Granny the Priest'] },
    undead: { icon: '💀', label: 'Undead', heroes: ['Lover Zombie'] }
};

// ============================================================
// MISSION DATA (100 missions)
// ============================================================

const STAGES = [
    {t: "Σιδερένια Καταπακτή", d: "Μια βαριά πύλη πέφτει με πάταγο. Μόνο ωμή δύναμη μπορεί να τη σηκώσει.", s: "pow", e: 4, h: 6, a: ['stone','tech']},
    {t: "Η Μεταφορά της Ταβέρνας", d: "Μετέφερε τα βαρέλια μπίρας στην αποθήκη της ταβέρνας.", s: "pow", e: 2, h: 4, a: ['pub']},
    {t: "Χαμένη Γάτα", d: "Βρες τη Yuumi. Τη γάτα του μεθυσμένου Panchoncho.", s: "wil", e: 2, h: 4, a: ['pub','shadow']},
    {t: "Ογκόλιθος στο Δρόμο", d: "Ένας βράχος σου κλείνει τον δρόμο. Μετακίνησέ τον.", s: "pow", e: 4, h: 9, a: ['stone','silent']},
    {t: "Καυγάς στην Ταβέρνα", d: "Συγκράτησε τον μεθυσμένο ορκ πριν καταστρέψει το μπαρ.", s: "pow", e: 3, h: 5, a: ['pub','stone']},
    {t: "Σπασμένα Δεσμά", d: "Σπάσε τις αλυσίδες πριν γυρίσουν οι φρουροί!", s: "pow", e: 4, h: 7, a: ['stone','shadow']},
    {t: "Ο Αγώνας του Καμπαναριού", d: "Όποιος χτυπήσει πρώτος την καμπάνα της ταβέρνας κερδίζει μια μπίρα.", s: "spd", e: 4, h: 9, a: ['pub','shadow']},
    {t: "Νανικό Αμόνι", d: "Σφυρηλάτησε το πυρακτωμένο μέταλλο με σωματική δύναμη.", s: "pow", e: 5, h: 9, a: ['stone','tech']},
    {t: "Παγίδα Συντριβής", d: "Οι τοίχοι κλείνουν! Βρες τον διακόπτη γρήγορα!", s: "spd", e: 5, h: 8, a: ['shadow','tech']},
    {t: "Νυχτερινή Βόλτα στην Ταβέρνα", d: "Περπάτα γρήγορα μέσα στο δάσος για να φτάσεις στην ταβέρνα τη νύχτα.", s: "spd", e: 4, h: 7, a: ['dark','shadow']},
    {t: "Πάλη με τον Νταή", d: "Ο νταής του χωριού σε προκαλεί. Ρίξ' τον κάτω!", s: "pow", e: 3, h: 6, a: ['stone','crowd']},
    {t: "Ο Φόρος της Μπίρας", d: "Πήγαινε στην ταβέρνα και φέρε στον King Antony 100 μπίρες.", s: "wil", e: 2, h: 4, a: ['pub','crowd']},
    {t: "Επισκευή Ανελκυστήρα", d: "Φτιάξε το σπασμένο σύστημα τροχαλίας για να βγεις από τον λάκκο!", s: "brn", e: 4, h: 7, a: ['tech','stone']},
    {t: "Ο Μοχλός του Excalibur", d: "Τράβηξε το θρυλικό σπαθί από την πέτρα!", s: "pow", e: 5, h: 10, a: ['stone','magic']},
    {t: "Σκοτεινό Κελάρι", d: "Το σκοτάδι ζωντανεύει. Τρέξε πριν σε πιάσει.", s: "spd", e: 5, h: 9, a: ['dark','shadow']},
    {t: "Διάβαση στα Σύννεφα", d: "Διέσχισε τη λεπτή κρεμαστή γέφυρα ψηλά στα σύννεφα.", s: "wil", e: 5, h: 8, a: ['sky','silent']},
    {t: "Βασιλικός Διαμεσολαβητής", d: "Ο King Antony μέθυσε πάλι. Βοήθησέ τον να κάνει φίλο έναν ορκ.", s: "cha", e: 4, h: 8, a: ['pub','crowd']},
    {t: "Η Πυρκαγιά της Ταβέρνας", d: "Η ταβέρνα καίγεται! Πρέπει να σώσεις τους μεθυσμένους!", s: "brn", e: 5, h: 8, a: ['shadow','tech']},
    {t: "Κυνηγητό στις Στέγες", d: "Κυνήγησε τον κλέφτη πάνω στις σκεπές του Pavel!", s: "spd", e: 4, h: 8, a: ['shadow','sky']},
    {t: "Μάζεμα Νομισμάτων", d: "Δεκάδες νομίσματα πέφτουν από τον πάγκο της ταβέρνας. Πιάσ' τα.", s: "spd", e: 4, h: 6, a: ['shadow','tech']},
    {t: "Εκκένωση Χωριού", d: "ΦΩΤΙΑ! Οδήγησε τους χωρικούς στην πλησιέστερη ασφαλή πόλη.", s: "brn", e: 5, h: 10, a: ['magic','tech']},
    {t: "Πλημμυρισμένη Ταβέρνα", d: "Η ταβέρνα πλημμυρίζει! Βρες πώς να σταματήσεις τη διαρροή!", s: "brn", e: 3, h: 6, a: ['pub','tech']},
    {t: "Το Ρακούν-Κλέφτης", d: "Ένα ρακούν σου έκλεψε το φαγητό. Κυνήγησέ το μέσα στην ταβέρνα.", s: "spd", e: 3, h: 6, a: ['shadow','sky']},
    {t: "Βαλς στο Πλήθος", d: "Χόρεψε μέσα στην κατάμεστη αίθουσα χωρίς να χτυπήσεις κανέναν!", s: "spd", e: 3, h: 5, a: ['crowd','shadow']},
    {t: "Η Πύλη Κλείνει", d: "Γλίστρα κάτω από την πύλη που κλείνει πριν παγιδευτείς!", s: "spd", e: 4, h: 7, a: ['shadow','stone']},
    {t: "Κολλώδες Πάτωμα", d: "Ο αλχημιστής έχυσε κόλλα! Κινήσου προσεκτικά αλλά γρήγορα!", s: "spd", e: 3, h: 6, a: ['shadow','magic']},
    {t: "Λεπίδες Μηχανισμού", d: "Πέρνα μέσα από την παγίδα με τις περιστρεφόμενες λεπίδες!", s: "spd", e: 5, h: 9, a: ['tech','shadow']},
    {t: "Χάδια Αντιπερισπασμού", d: "Κράτα τη Yuumi απασχολημένη ενώ οι άλλοι περνούν κρυφά!", s: "cha", e: 2, h: 4, a: ['pub','silent']},
    {t: "Ο Κύβος του Antony", d: "Λύσε τον γρίφο του βασιλιά για να αποδείξεις την αξία σου!", s: "brn", e: 4, h: 8, a: ['tech','magic']},
    {t: "Ο Καθρέφτης του Λιτς", d: "Απάντησε στους γρίφους του αζώου για να περάσεις με ασφάλεια!", s: "brn", e: 5, h: 9, a: ['undead','dark']},
    {t: "Η Χρυσή Επιδιόρθωση", d: "Επισκεύασε το χρυσό άγαλμα πριν το προσέξει ο βασιλιάς!", s: "brn", e: 3, h: 6, a: ['tech','crowd']},
    {t: "Ο Γρίφος του Panchonco", d: "Λύσε τον μεθυσμένο γρίφο του Panchonco για ένα δωρεάν ποτό!", s: "brn", e: 3, h: 5, a: ['pub','tech']},
    {t: "Μνήμη της Κρύπτης", d: "Θυμήσου τη σειρά των συμβόλων για να δραπετεύσεις από την κρύπτη!", s: "brn", e: 4, h: 8, a: ['undead','dark']},
    {t: "Μεθυσμένος Λογαριασμός", d: "Είσαι μεθυσμένος! Υπολόγισε σωστά τον λογαριασμό της ταβέρνας!", s: "brn", e: 2, h: 4, a: ['pub','tech']},
    {t: "Αφέντης του Χάρτη", d: "Βρες την έξοδο σε έναν μεταβαλλόμενο, σκοτεινό λαβύρινθο.", s: "brn", e: 5, h: 10, a: ['dark','shadow']},
    {t: "Ουράνια Διπλωματία", d: "Η φυλή των δράκων θέλει να εισβάλει. Διαπραγματεύσου μαζί τους.", s: "brn", e: 4, h: 8, a: ['sky','crowd']},
    {t: "Η Νυσταγμένη Συνοδεία", d: "Οδήγησε τον υπνοβάτη ευγενή πίσω στο κρεβάτι του με ασφάλεια!", s: "brn", e: 3, h: 5, a: ['crowd','silent']},
    {t: "Πλαστά Χρυσά", d: "Εντόπισε τα πλαστά νομίσματα πριν τα προσέξει ο έμπορος!", s: "brn", e: 4, h: 7, a: ['tech','shadow']},
    {t: "Το Κοκτέιλ του Panchonco", d: "Ο Panchonco θέλει κοκτέιλ. Ανακάτεψε τα ποτά.", s: "brn", e: 3, h: 6, a: ['pub','tech']},
    {t: "Ο Γρίφος του Μπάρμαν", d: "Απάντησε στους τρεις γρίφους του μυστηριώδη μπάρμαν!", s: "brn", e: 4, h: 7, a: ['pub','magic']},
    {t: "Κρυπτογραφημένη Κλειδαριά", d: "Αποκρυπτογράφησε τον αρχαίο κώδικα για να ανοίξεις το θησαυροφυλάκιο!", s: "brn", e: 5, h: 9, a: ['tech','magic']},
    {t: "Δρακοκτόνος", d: "Ξεγέλασε τον δράκο με ένα έξυπνο σχέδιο μάχης!", s: "brn", e: 5, h: 10, a: ['sky','tech']},
    {t: "Μεταμφίεση στην Ταβέρνα", d: "Φέρσου φυσικά για να αποφύγεις τους φρουρούς που ψάχνουν την ταβέρνα!", s: "cha", e: 3, h: 5, a: ['pub','shadow']},
    {t: "Η Εύνοια του Βασιλιά", d: "Εντυπωσίασε τον μεθυσμένο βασιλιά με μια ψεύτικη ιστορία.", s: "cha", e: 3, h: 6, a: ['crowd','pub']},
    {t: "Ψυχολογικό Παιχνίδι", d: "Πείσε τον πέτρινο γκόλεμ ότι είναι φτιαγμένος από ξύλο!", s: "cha", e: 4, h: 8, a: ['stone','magic']},
    {t: "Κολακεία στον Old Nick", d: "Κέρδισε τη φιλία του γέρου Old Nick με κολακεία.", s: "cha", e: 3, h: 6, a: ['pub','crowd']},
    {t: "Κουβέντα με τον Μπράβο", d: "Γοήτεψε τον πέτρινο γκόλεμ για να σε αφήσει να περάσεις.", s: "cha", e: 5, h: 10, a: ['crowd','magic','tech']},
    {t: "Το Τραγούδι του Panchonco", d: "Τραγούδησε ένα τραγούδι που θα κάνει τον μεθυσμένο Panchoncho να δακρύσει.", s: "cha", e: 4, h: 8, a: ['pub','silent']},
    {t: "Περίπολος Ορκ στον Βάλτο", d: "Πείσε την περίπολο των ορκ ότι ανήκεις στον βάλτο!", s: "cha", e: 4, h: 7, a: ['silent','crowd']},
    {t: "Ψίθυρος στη Σκιά", d: "Πείσε τα σκοτεινά πνεύματα του δάσους να φωτίσουν τον δρόμο.", s: "cha", e: 4, h: 7, a: ['crowd','silent','dark']},
    {t: "Σιωπηλή Ικεσία", d: "Μετέδωσε την επείγουσα ανάγκη σου χωρίς να μιλήσεις!", s: "cha", e: 3, h: 6, a: ['silent','crowd']},
    {t: "Διαπραγματευτής των Ουρανών", d: "Φέρε ειρήνη ανάμεσα στους γίγαντες των σύννεφων!", s: "cha", e: 5, h: 9, a: ['sky','crowd']},
    {t: "Παγίδα Αριστοκράτη", d: "Τελείωσε τη βαρετή συζήτηση χωρίς να γίνεις αγενής.", s: "cha", e: 3, h: 6, a: ['crowd','silent']},
    {t: "Ο Μηχανικός Εφευρέτης", d: "Πείσε τον εφευρέτη να μοιραστεί τα μυστικά του!", s: "cha", e: 4, h: 7, a: ['tech','crowd']},
    {t: "Θεϊκή Πρόποση", d: "Φώναξε τόσο δυνατά ώστε να σε ακούσουν οι θεοί.", s: "cha", e: 5, h: 10, a: ['sky','crowd']},
    {t: "Φορολογικός Έλεγχος", d: "Ξεφύτρωσε με τα λόγια σου από τον φορολογικό έλεγχο!", s: "cha", e: 4, h: 8, a: ['crowd','tech']},
    {t: "Πειρασμός της Ταβέρνας", d: "Η μπίρα μυρίζει παράδεισο. Μείνε συγκεντρωμένος.", s: "wil", e: 3, h: 6, a: ['undead','silent']},
    {t: "Ο Ψίθυρος του Κενού", d: "Φωνές υπόσχονται δύναμη με αντάλλαγμα την ψυχή σου. Αντιστέκεσαι;", s: "wil", e: 4, h: 8, a: ['dark','undead','tech']},
    {t: "Μοναστική Σιωπή", d: "Κάθισε ακίνητος ενώ έντομα σέρνονται πάνω στο δέρμα σου.", s: "wil", e: 3, h: 6, a: ['silent','dark','undead']},
    {t: "Δαιμονική Ενοχή", d: "Ο δαίμονας σου δείχνει τις χειρότερες αναμνήσεις σου. Άντεξε!", s: "wil", e: 5, h: 9, a: ['dark','magic']},
    {t: "Ατέλειωτη Σκάλα", d: "Ανέβα τα ατελείωτα σκαλιά χωρίς να χάσεις την ελπίδα σου!", s: "wil", e: 4, h: 8, a: ['magic','silent']},
    {t: "Πέτρινη Μεταμόρφωση", d: "Αντιστάσου στο βλέμμα της μέδουσας καθώς πλησιάζεις!", s: "wil", e: 5, h: 9, a: ['stone','magic']},
    {t: "Σταμάτα τον Τραγουδιστή", d: "Μην αφήσεις το μαγευτικό τραγούδι του βάρδου να σε ελέγξει!", s: "wil", e: 4, h: 7, a: ['magic','crowd']},
    {t: "Το Καταραμένο Δαχτυλίδι", d: "Βγάλε το δαχτυλίδι που ψιθυρίζει σκοτεινούς πειρασμούς!", s: "wil", e: 5, h: 10, a: ['magic','dark']},
