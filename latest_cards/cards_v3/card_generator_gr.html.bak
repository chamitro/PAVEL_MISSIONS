const GROUP_STAGES = [
    {t: "Η Μεγάλη Πλημμύρα του Βάλτου", d: "Το Pavel βυθίζεται! Αδειάστε όλοι μαζί το νερό από τον βάλτο.", s: "pow", e: 10, h: 15, a: ['silent','stone']},
    {t: "Αντίσταση στην Ορδή των Ορκ", d: "Σπρώξτε πίσω την εφόρμηση της εμπροσθοφυλακής των ορκ όλοι μαζί!", s: "pow", e: 12, h: 16, a: ['stone','undead']},
    {t: "Ο Βράχος του Γίγαντα", d: "Ένας γίγαντας του βουνού φράζει το μονοπάτι. Τραβήξτε τον ογκόλιθο!", s: "pow", e: 10, h: 18, a: ['stone','silent']},
    {t: "Ο Αγώνας με τα Βαρέλια Μπύρας", d: "Κυλήστε τα τεράστια βαρέλια στην ταβέρνα πριν κλείσει!", s: "pow", e: 8, h: 13, a: ['pub','stone']},
    {t: "Παραβίαση της Πύλης του Κάστρου", d: "Γκρεμίστε τις πύλες του κάστρου όλοι μαζί!", s: "pow", e: 11, h: 17, a: ['stone','tech']},
    {t: "Η Πολιορκία του Δράκου", d: "Αποφύγετε τις μπάλες φωτιάς που ρίχνει ο μεθυσμένος δράκος!", s: "spd", e: 12, h: 17, a: ['sky','shadow']},
    {t: "Κινούμενοι Τοίχοι", d: "Περάστε τον μεταμορφωνόμενο λαβύρινθο πριν σας συνθλίψουν οι τοίχοι!", s: "spd", e: 10, h: 15, a: ['shadow','tech']},
    {t: "Ενέδρα στην Ομίχλη", d: "Ξεφύγετε από τους ληστές μέσα στην πυκνή ομίχλη όλοι μαζί!", s: "spd", e: 9, h: 14, a: ['shadow','dark']},
    {t: "Η Πυροσβεστική του Χωριού", d: "Η ταβέρνα καίγεται! Περάστε τα σακιά με νερό αστραπιαία.", s: "spd", e: 8, h: 13, a: ['pub','shadow']},
    {t: "Τρέξτε στην Αστραπόβροντη", d: "Φτάστε σε καταφύγιο πριν χτυπήσει η μαγική καταιγίδα!", s: "spd", e: 11, h: 16, a: ['magic','shadow']},
    {t: "Αναζήτηση των Χαμένων Παιδιών", d: "Πλοηγηθείτε μέσα στις μεταβαλλόμενες ομίχλες με καθαρή λογική.", s: "brn", e: 10, h: 15, a: ['magic','silent']},
    {t: "Επισκευή του Μαγικού Φράγματος", d: "Επαναβαθμονομήστε την ασπίδα του χωριού. Συγκέντρωση!", s: "brn", e: 9, h: 14, a: ['tech','magic']},
    {t: "Κατασκευή Γέφυρας", d: "Σχεδιάστε και χτίστε μια γέφυρα πάνω από το φαράγγι!", s: "brn", e: 10, h: 15, a: ['tech','stone']},
    {t: "Το Αίνιγμα της Σφίγγας", d: "Απαντήστε στα αρχαία αινίγματα της Σφίγγας ως ομάδα!", s: "brn", e: 11, h: 16, a: ['magic','undead']},
    {t: "Η Κρίση του Αλχημιστή", d: "Το φίλτρο είναι ασταθές! Υπολογίστε τη λύση όλοι μαζί!", s: "brn", e: 9, h: 14, a: ['tech','magic']},
    {t: "Μοναστική Χορωδία", d: "Τραγουδήστε σε τέλεια αρμονία για να μπείτε στην ιερή πόλη.", s: "cha", e: 7, h: 12, a: ['silent','sky']},
    {t: "Η Τελευταία Πρόποση", d: "Οδηγήστε την ταβέρνα στο πιο επικό τραγούδι που ακούστηκε ποτέ.", s: "cha", e: 7, h: 12, a: ['pub','crowd']},
    {t: "Διαπραγμάτευση με τον Δράκο", d: "Πείστε το συμβούλιο των δράκων να λυπηθεί το χωριό!", s: "cha", e: 11, h: 16, a: ['sky','crowd']},
    {t: "Η Χάρη του Βασιλιά", d: "Υπερασπιστείτε την υπόθεσή σας ενώπιον του King Antony όλοι μαζί!", s: "cha", e: 9, h: 14, a: ['crowd','pub']},
    {t: "Το Πανηγύρι του Χωριού", d: "Οργανώστε τη γιορτή για να ενώσετε τους κατοίκους!", s: "cha", e: 8, h: 13, a: ['crowd','pub']},
    {t: "Το Βασιλικό Συμπόσιο", d: "Αντισταθείτε στον πειρασμό να πιείτε και τις 5000 μπύρες!", s: "wil", e: 8, h: 13, a: ['pub','undead']},
    {t: "Η Σιωπηλή Αγρύπνια", d: "Κάντε βάρδια όλη νύχτα χωρίς να σας πάρει ο ύπνος!", s: "wil", e: 9, h: 14, a: ['silent','dark']},
    {t: "Καθαρισμός Ταβέρνας", d: "Αντέξτε τον καθαρισμό του χειρότερου χάλιου που είδε ποτέ το Pavel!", s: "wil", e: 7, h: 12, a: ['pub','silent']},
    {t: "Η Μεθυσμένη Παρέλαση", d: "Βαδίστε μέσα στην πόλη αντιστεκόμενοι σε κάθε περισπασμό!", s: "wil", e: 8, h: 13, a: ['crowd','pub']},
    {t: "Οι Ιστορίες του Nick", d: "Κρατήστε τη θέση σας απέναντι στον γέρο Nick πριν αρχίσει κι άλλη ιστορία!", s: "wil", e: 8, h: 13, a: ['silent','crowd']},
    {t: "Το Τουρνουά Μπρα-ντε-Φερ του Panchoncho", d: "Ο Panchoncho σε μπλακάουτ νικάει ΟΛΟΥΣ. Κερδίζει συνέχεια. Μόλις στέκεται. Πώς γίνεται;!", s: "pow", e: 12, h: 18, a: ['pub','stone']},
    {t: "Η Βασιλική Εκτόξευση Βαρελιού", d: "Ο King Antony θέλει να εκτοξευτεί ένα βαρέλι πάνω από το τείχος του κάστρου για 'διπλωματικούς λόγους'. Χωρίς ερωτήσεις.", s: "pow", e: 10, h: 16, a: ['pub','stone']},
    {t: "Η Yuumi σε Πανύψηλο Δέντρο", d: "Η γάτα του Panchoncho σκαρφάλωσε στο ψηλότερο δέντρο στο Pavel και κρίνει τους πάντες από ψηλά. Κατεβάστε την!", s: "pow", e: 9, h: 15, a: ['pub','sky']},
    {t: "Η Πόρτα της Ταβέρνας Κόλλησε Πάλι", d: "Η πόρτα της ταβέρνας πάγωσε. Τον Ιούλιο. Κάτι πάει πολύ στραβά. Σπρώξτε!", s: "pow", e: 8, h: 14, a: ['pub','magic']},
    {t: "Διελκυστίνδα με Τρολ", d: "Ένα μπερδεμένο τρολ άρπαξε ένα σχοινί και δεν το αφήνει. Φαίνεται να διασκεδάζει. Τραβήξτε δυνατότερα!", s: "pow", e: 11, h: 17, a: ['stone','silent']},
    {t: "Η Yuumi Έκλεψε το Βασιλικό Στέμμα", d: "Η γάτα φοράει το στέμμα του King Antony και τρέχει σαν τρελή σε όλο το Pavel. Η Μεγαλειότητά του ΔΕΝ διασκεδάζει.", s: "spd", e: 10, h: 15, a: ['pub','shadow']},
    {t: "Το Περιστατικό με τις Θυμωμένες Μέλισσες", d: "Κάποιος — δεν λέμε ποιος — αναποδογύρισε την κυψέλη. Οι μέλισσες έχουν ΑΠΟΨΗ. ΤΡΕΞΤΕ!", s: "spd", e: 11, h: 16, a: ['sky','shadow']},
    {t: "Καυτή Πατάτα, Κυριολεκτικά Καυτή", d: "Ένας μπερδεμένος μάγος σας έδωσε μια κανονική μπάλα φωτιάς. Πασάρτε τη γρήγορα πριν χάσει κάποιος χέρι!", s: "spd", e: 12, h: 17, a: ['magic','shadow']},
    {t: "Το Ακυβέρνητο Κάρο Μπύρας", d: "Το κάρο με τις μπύρες δεν έχει οδηγό, δεν έχει φρένα και κατευθύνεται στην ταβέρνα. Κουνηθείτε, ΤΩΡΑ!", s: "spd", e: 9, h: 14, a: ['pub','shadow']},
    {t: "Ο Μεγάλος Αγώνας Κύλισης Βαρελιών", d: "Η τελευταία ομάδα που κυλάει το βαρέλι στην ταβέρνα κερνάει τον επόμενο γύρο. Κανείς δεν θέλει να κεράσει. ΣΠΡΙΝΤ!", s: "spd", e: 8, h: 13, a: ['pub','stone']},
    {t: "Το Αδύνατο Κουίζ του Old Nick", d: "Ο Old Nick εξετάζει αν ΠΡΑΓΜΑΤΙΚΑ ακούγατε την 6ωρη ιστορία του. Ερώτηση-παγίδα: κανείς δεν άκουγε.", s: "brn", e: 9, h: 14, a: ['pub','silent']},
    {t: "Το Πρόβλημα με το Λάθος Φίλτρο", d: "Ο Panchoncho ήπιε κάτι μοβ και τώρα μιλάει ανάποδα και αιωρείται ελαφρώς. Βρείτε το αντίδοτο!", s: "brn", e: 10, h: 15, a: ['magic','pub']},
    {t: "Τα Βασιλικά Μαθηματικά Φορολογίας του King Antony", d: "Ο βασιλιάς κάνει φορολογική δήλωση μετά από 14 μπύρες. Χρωστάει λεφτά στον εαυτό του κάπως. Φτιάξτε το αμέσως.", s: "brn", e: 11, h: 16, a: ['pub','crowd']},
    {t: "Η Μεθυσμένη Φιλοσοφία του Panchoncho", d: "Αποκρυπτογραφήστε τη μπερδεμένη σοφία του Panchoncho πριν λιποθυμήσει στη μέση της πρότασης. Λέει ότι είναι επείγον. Δεν είναι.", s: "brn", e: 8, h: 13, a: ['pub','silent']},
    {t: "Ο Ανάποδος Χάρτης", d: "Κάποιος ζωγράφισε χάρτη του Pavel μετά από τρεις μπύρες. Ο βορράς είναι εκεί που πρέπει να είναι ο νότος. Βρείτε τον δρόμο σπίτι. Καλή τύχη.", s: "brn", e: 9, h: 15, a: ['pub','tech']},
    {t: "Ο Δράκος Προσβλήθηκε", d: "Κάποιος τον αποκάλεσε 'μεγάλη σαύρα'. Το άκουσε. Είναι στην πόρτα της ταβέρνας. Μαλακώστε το ΤΩΡΑ ΑΜΕΣΩΣ.", s: "cha", e: 10, h: 15, a: ['sky','crowd']},
    {t: "Η Βραδιά Καραόκε του King Antony", d: "Ο βασιλιάς επιμένει ότι έχει υπέροχη φωνή. Πείτε του ότι αληθεύει χωρίς να πείτε ψέματα. Με κάποιον τρόπο.", s: "cha", e: 9, h: 14, a: ['pub','crowd']},
    {t: "Η Μεγάλη Περιοδεία Συγγνωμών", d: "Μετά το 'περιστατικό' της χθεσινής βραδιάς, κάθε κάτοικος του Pavel χρειάζεται προσωπική συγγνώμη. Εσείς φταίτε.", s: "cha", e: 11, h: 16, a: ['pub','crowd']},
    {t: "Κατεβάστε τον Nick από τη Σκηνή", d: "Ο Old Nick άρπαξε το λαούτο του βάρδου και δεν σταματάει. Είναι στο πέμπτο ανκόρ. Κανείς δεν ζήτησε.", s: "cha", e: 8, h: 13, a: ['pub','crowd']},
    {t: "Το Τυχαίο Σόου Ταλέντων", d: "Ο Panchoncho έγραψε τους πάντες να εμφανιστούν. Το χωριό παρακολουθεί. Κανείς δεν ετοίμασε τίποτα.", s: "cha", e: 10, h: 16, a: ['pub','crowd']},
    {t: "Το Καταραμένο Πρόποσης-Παιχνίδι του Panchoncho", d: "Οι κανόνες είναι απλοί: μην τιναχτείτε. Ο Panchoncho μόλις αποκάλυψε ένα φίδι κατοικίδιο που λέγεται 'Εφοριακός'.", s: "wil", e: 9, h: 14, a: ['pub','undead']},
    {t: "Η Τετράωρη Ιστορία για Ύπνο του Nick", d: "Μείνετε ξύπνιοι μέχρι να τελειώσει ο Nick την ιστορία του. Δεν έχει τελειώσει ιστορία από τη Χρονιά του Ορκ.", s: "wil", e: 10, h: 15, a: ['pub','silent']},
    {t: "Η Κατάσταση στο Υπόγειο της Ταβέρνας", d: "Το υπόγειο της ταβέρνας δεν έχει καθαριστεί από την εποχή του παππού του King Antony. Κατεβείτε στην καταπακτή. Μαζί.", s: "wil", e: 8, h: 13, a: ['pub','silent']},
