    {t: "Αντηχήσεις Φόβου", d: "Περπάτα στον στοιχειωμένο διάδρομο χωρίς να το βάλεις στα πόδια!", s: "wil", e: 4, h: 8, a: ['dark','undead']},
    {t: "Πύρινο Πνεύμα", d: "Το πάτωμα της ταβέρνας καταρρέει. Ηρέμησε και διέσχισέ το!", s: "wil", e: 5, h: 10, a: ['sky','silent']},
    {t: "Ο Αντιβασιλέας", d: "Αντιστάσου στον πειρασμό να κάνεις κατάχρηση της προσωρινής εξουσίας!", s: "wil", e: 4, h: 7, a: ['crowd','magic']},
    {t: "Βασιλική Μπιρομαχία", d: "Κέρδισε μια μπιρομαχία ενάντια στον King Antony!", s: "wil", e: 3, h: 6, a: ['pub','crowd']},
    {t: "Το Βάρος του Ήρωα", d: "Σήκωσε το βάρος της ευθύνης χωρίς να λυγίσεις!", s: "wil", e: 5, h: 9, a: ['silent','crowd']},
    {t: "Χιονοστιβάδα Βαρελιών", d: "Βαρέλια μπίρας κυλούν από τις σκάλες της ταβέρνας. Απόφυγέ τα όλα!", s: "spd", e: 4, h: 8, a: ['magic','shadow']},
    {t: "Φλεγόμενα Βέλη", d: "Απόφυγε τη βροχή φλεγόμενων βελών!", s: "spd", e: 5, h: 9, a: ['shadow','sky']},
    {t: "Γέφυρα που Καταρρέει", d: "Τρέξε να περάσεις πριν καταρρεύσει η γέφυρα!", s: "spd", e: 4, h: 8, a: ['shadow','stone']},
    {t: "Η Yuumi και τα Κλειδιά", d: "Η Yuumi πήρε τα κλειδιά σου. ΠΙΑΣ' ΤΗΝ!", s: "spd", e: 3, h: 6, a: ['shadow','pub']},
    {t: "Κυνηγητό Κεραυνών", d: "Τρέξε πιο γρήγορα από τους μαγικούς κεραυνούς!", s: "spd", e: 5, h: 10, a: ['magic','shadow']},
    {t: "Δηλητηριώδες Αέριο στον Βάλτο", d: "Φύγε μακριά από το τοξικό σύννεφο αερίου στον βάλτο!", s: "spd", e: 4, h: 7, a: ['silent','shadow']},
    {t: "Η Ανάσα του Δράκου", d: "Εσύ εναντίον της Yuumi. Ποιος είναι πιο γρήγορος!", s: "spd", e: 3, h: 6, a: ['shadow','sky']},
    {t: "Τα Στιλέτα του Δολοφόνου", d: "Απόφυγε τα μαχαίρια που πετάει ο δολοφόνος!", s: "spd", e: 5, h: 9, a: ['shadow','dark']},
    {t: "Πάτωμα που Θρυμματίζεται", d: "Πήδα από πλακάκι σε πλακάκι καθώς το πάτωμα καταρρέει!", s: "spd", e: 4, h: 8, a: ['shadow','stone']},
    {t: "Κυνηγητό στην Ταβέρνα", d: "Πιάσε τη Yuumi πριν καταλάβει ο Panchoncho ότι έφυγε!", s: "spd", e: 3, h: 5, a: ['pub','shadow']},
    {t: "Ο Πολυέλαιος Πέφτει", d: "Πιάσε τον πολυέλαιο που πέφτει πριν συνθλίψει κάποιον!", s: "pow", e: 4, h: 7, a: ['pub','stone']},
