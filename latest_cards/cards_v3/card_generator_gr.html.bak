    {t: "Σπάσιμο Αλυσίδων", d: "Σπάσε τις αλυσίδες που κρατούν τον φυλακισμένο!", s: "pow", e: 4, h: 7, a: ['stone','dark']},
    {t: "Μάχη με τον Panchonco", d: "Ο μεθυσμένος Panchonco σου κλείνει τον δρόμο. Πολέμα ή διαπραγματεύσου!", s: "pow", e: 4, h: 8, a: ['stone','crowd','sky']},
    {t: "Σήκωμα Βαρελιού", d: "Εντυπωσίασε έναν νάνο σηκώνοντας το βαρύτερο βαρέλι μπίρας του!", s: "pow", e: 3, h: 6, a: ['stone','undead']},
    {t: "Νανούρισμα Δράκου", d: "Νανούρισε τον μεθυσμένο δράκο πριν κάψει το χωριό!", s: "cha", e: 5, h: 9, a: ['crowd','pub','sky']},
    {t: "Συνθήκη Ειρήνης Ορκ", d: "Πείσε τον αρχηγό των ορκ ότι η ειρήνη είναι κερδοφόρα!", s: "cha", e: 5, h: 10, a: ['crowd','stone']},
