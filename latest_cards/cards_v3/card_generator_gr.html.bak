    {t: "Το Τραγούδι της Σειρήνας", d: "Αντιστάσου στο κάλεσμα της σειρήνας και βρες την πηγή του!", s: "wil", e: 5, h: 10, a: ['magic','sky']},
    {t: "Βασίλειο Εφιαλτών", d: "Παγιδευμένος σε κατάρα ονείρων γεμάτη εφιάλτες. Ξύπνα με τη δύναμη της θέλησής σου!", s: "wil", e: 6, h: 10, a: ['dark','magic']}
