    {t: "Διαπραγμάτευση με Πνεύμα", d: "Πείσε το θυμωμένο φάντασμα να βρει ειρήνη!", s: "cha", e: 4, h: 8, a: ['undead','silent']},
    {t: "Η Εμπιστοσύνη του King Antony", d: "Κέρδισε την εμπιστοσύνη του King Antony με τα λόγια σου!", s: "cha", e: 4, h: 7, a: ['pub','crowd']},
    {t: "Συμφωνία με τον Διάβολο", d: "Διαπραγματεύσου με τον δαιμόνιο χωρίς να χάσεις την ψυχή σου!", s: "cha", e: 5, h: 9, a: ['tech','dark','magic']},
    {t: "Μεθυσμένος Μάγος", d: "Πείσε τον μεθυσμένο μάγο να ρίξει το σωστό ξόρκι!", s: "cha", e: 4, h: 8, a: ['magic','pub']},
    {t: "Αντίδοτο Δηλητηρίου", d: "Κάτι έχει η μπίρα μου! Ανακάτεψε τα σωστά βότανα για να σωθείς!", s: "brn", e: 4, h: 8, a: ['magic','silent']},
    {t: "Μηχανισμός Παγίδας", d: "Βρες πώς να απενεργοποιήσεις την πολύπλοκη παγίδα!", s: "brn", e: 5, h: 9, a: ['tech','shadow']},
